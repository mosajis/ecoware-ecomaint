  typeboxImportDependencyName = "elysia"
  typeboxImportVariableName   = "t"
}

datasource db {
  provider = "sqlserver"
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model AllTable {
  tableName    String?  @map("TableName") @db.NVarChar(100)
  sequenceName String?  @map("SequenceName") @db.NVarChar(100)
  tableId      String?  @map("TableID") @db.NVarChar(100)
  isNew        Boolean? @map("IsNew")
  instId       Int?     @map("InstId")

  @@map("All_Table")
  @@ignore
}

